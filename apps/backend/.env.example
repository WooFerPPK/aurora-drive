# Forza Telemetry Backend — example env
# Local-first. Copy to .env and adjust if needed.
# DO NOT add an Anthropic LLM API key here. The LLM is invoked via
# `claude -p` headless mode (constitution Principle III).

FH6_LISTEN_ADDR=127.0.0.1
FH6_LISTEN_PORT=5302
FH6_HTTP_HOST=127.0.0.1
FH6_HTTP_PORT=8000

FH6_DB_DSN=postgresql+asyncpg://fh6:fh6@127.0.0.1:5432/fh6
# Integration tests target a separate database. If unset, the test
# fixture derives it by swapping /fh6 → /fh6_test in FH6_DB_DSN.
# One-time setup: `make db.test.setup` (creates the database as
# postgres superuser and installs the timescaledb extension).
# FH6_TEST_DB_DSN=postgresql+asyncpg://fh6:fh6@127.0.0.1:5432/fh6_test

FH6_LLM_DRY_RUN=false
FH6_LOG_LEVEL=INFO
FH6_LOG_FORMAT=pretty
